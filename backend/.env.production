# ── Production Environment ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/rizzbot
JWT_SECRET=CHANGE-ME-TO-A-LONG-RANDOM-SECRET
JWT_EXPIRY_HOURS=720

# Firebase
FIREBASE_SERVICE_ACCOUNT=/etc/secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
# Or use inline JSON (preferred for container deployments):
# FIREBASE_SERVICE_ACCOUNT_JSON=<paste full JSON here>

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Rate limits
DAILY_FREE_LIMIT=5

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# App
ENVIRONMENT=production
LOG_LEVEL=WARNING
CORS_ORIGINS=["https://yourdomain.com"]
