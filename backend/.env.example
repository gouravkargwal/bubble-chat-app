# Copy to .env.dev (local) or .env.prod (production)
# Use "postgres" as host for Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://cookd:cookd@postgres:5432/cookd
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY_HOURS=720
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
SIGNUP_PROMO_CODE=WELCOME
ENVIRONMENT=development
VOICE_DNA_ENABLED=false
LOG_LEVEL=INFO
# LOG_SERVICE_NAME=api

# Firebase Authentication
FIREBASE_SERVICE_ACCOUNT=          # path to service account JSON file
FIREBASE_PROJECT_ID=               # your Firebase project ID
# FIREBASE_SERVICE_ACCOUNT_JSON=   # OR paste inline JSON here

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# RevenueCat webhooks (required when ENVIRONMENT is production/staging)
REVENUECAT_WEBHOOK_SECRET=

# OCI Object Storage
OCI_CONFIG_FILE=/app/oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_BUCKET_NAME=your-bucket-name-from-console
OCI_NAMESPACE=your-object-storage-namespace
OCI_PAR_EXPIRY_HOURS=1

# ──────────────────────────────────────────────────────────────────────────
# OpenObserver (unified observability: logs, metrics, traces)
# All vars below are used by both docker-compose.yml and docker-compose.prod.yml.
# Use .env.dev for local development, .env.prod for production.
# ──────────────────────────────────────────────────────────────────────────

# App → OpenObserver connection (container name, resolves inside Docker)
OPENOBSERVER_ENDPOINT=http://openobserver:5001

# API key for OTLP ingestion. Generate in OpenObserver UI → Settings → API Keys.
# Leave empty for dev (no auth).
OPENOBSERVER_API_KEY=

# Service name tag for all observability signals
OPENOBSERVER_SERVICE_NAME=rizzbot-api

# Master switch and trace sampling (0.0–1.0). 0.1 = trace 10% of requests.
OTLP_ENABLED=true
OTLP_SAMPLE_RATE=0.1

# ── OpenObserver admin credentials ───────────────────────────────────────
# These configure the OpenObserver container itself (not the app).
# Required on FIRST startup. Generate a strong password for production:
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#%^&*') for _ in range(28)))"
ZO_ROOT_USER_EMAIL=admin@rizzbot.dev
ZO_ROOT_USER_PASSWORD=change-me-to-a-strong-random-password

# PostgreSQL connection for OpenObserver metadata storage.
# Both dev and prod now use Postgres (not SQLite).
# The 'openobserver' database is auto-created by initdb/002_create_openobserver_db.sql.
ZO_POSTGRES_DSN=postgres://cookd:cookd@postgres:5432/openobserver

# Data directory for OpenObserver's internal columnar storage
ZO_DATA_DIR=/data
