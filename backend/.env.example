# Copy to .env.dev (local) or .env.prod (production)
# Use "postgres" as host for Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://cookd:cookd@postgres:5432/cookd
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY_HOURS=720
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
SIGNUP_PROMO_CODE=WELCOME
ENVIRONMENT=development
# Voice DNA (screenshot calibration + style learning). Set true only when re-enabled in product.
VOICE_DNA_ENABLED=false
LOG_LEVEL=INFO
# JSON log field `service_name` (match Docker Compose service name for Loki label alignment)
# LOG_SERVICE_NAME=api

# Firebase Authentication
FIREBASE_SERVICE_ACCOUNT=          # path to service account JSON file
FIREBASE_PROJECT_ID=               # your Firebase project ID
# FIREBASE_SERVICE_ACCOUNT_JSON=   # OR paste inline JSON here

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# RevenueCat webhooks (required when ENVIRONMENT is production/staging). Use the same string as
# RevenueCat → Webhooks → "Authorization header value" (raw or Bearer; both are accepted).
REVENUECAT_WEBHOOK_SECRET=

# OCI Object Storage (required for profile auditor uploads / signed URLs; no local disk fallback)
# OCI_NAMESPACE may be left empty to auto-detect from the API after auth.
# Put config + .pem in backend/oci/. First line of config MUST be "[DEFAULT]" (INI section).
# Copy oci/config.example → oci/config and edit. key_file must match container/host path:
#   Docker (compose mounts repo as /app): key_file=/app/oci/oci_api_key.pem → OCI_CONFIG_FILE=/app/oci/config
#   Host, cwd=backend: key_file=oci/oci_api_key.pem → OCI_CONFIG_FILE=oci/config
# Or use ~/.oci/config and leave OCI_CONFIG_FILE unset (app default).
OCI_CONFIG_FILE=/app/oci/config
OCI_CONFIG_PROFILE=DEFAULT
# Must match the bucket name in OCI exactly (e.g. cookd-assests vs cookd-assets)
OCI_BUCKET_NAME=your-bucket-name-from-console
OCI_NAMESPACE=your-object-storage-namespace
OCI_PAR_EXPIRY_HOURS=1

# Production Grafana (docker-compose.prod.yml). The grafana service uses env_file: .env.prod — set the
# variable name Grafana expects (not GRAFANA_*): required on first deploy with a strong random password.
GF_SECURITY_ADMIN_PASSWORD=
#
# Local docker-compose.yml: optional GRAFANA_ADMIN_PASSWORD in root `.env` (defaults to admin if unset).
#
# Grafana: if Logs Drilldown says "Unable to load datasource meta data", a saved tab/bookmark still points at
# an old datasource UID. Re-select "Loki" in the drilldown UI, or open Drilldown from the sidebar (fresh URL).