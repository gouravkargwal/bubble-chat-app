# ── Staging Environment ──────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./rizzbot_staging.db
JWT_SECRET=staging-secret-change-me
JWT_EXPIRY_HOURS=720

# Firebase
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=
# Or use inline JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Rate limits
DAILY_FREE_LIMIT=10

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.5

# App
ENVIRONMENT=staging
LOG_LEVEL=DEBUG
CORS_ORIGINS=["*"]
