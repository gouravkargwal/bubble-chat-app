# ⚠️  NEVER COMMIT THIS FILE WITH REAL SECRETS!
# Copy to .env.dev (local) or .env.prod (production) — both are gitignored.
# If you exposed a key accidentally, see SECURITY.md for rotation instructions.
# Use "postgres" as host for Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://cookd:cookd@postgres:5432/cookd
JWT_EXPIRY_HOURS=720
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
SIGNUP_PROMO_CODE=WELCOME
ENVIRONMENT=development
VOICE_DNA_ENABLED=false
LOG_LEVEL=INFO
# LOG_SERVICE_NAME=api

# Firebase Authentication
FIREBASE_SERVICE_ACCOUNT=          # path to service account JSON file
FIREBASE_PROJECT_ID=               # your Firebase project ID
# FIREBASE_SERVICE_ACCOUNT_JSON=   # OR paste inline JSON here

# PayU (LTD payments — Indian payment gateway)
# ──────────────────────────────────────────────────────────────────────────
# Two authentication schemes exist side by side on the PayU platform:
#
# 1. LEGACY HASH (used in our `_payu_hash` / `_verify_payu_hash` helpers):
#    - Key:  Merchant key from PayU Dashboard → API Keys → "key" field
#    - Salt: The "Salt- 32 bit" value (NOT the 256-bit salt)
#    - Used for: HTML form POST checkout, hash verification on redirect
#    - Location in your dashboard: Developers → API Keys → Salt- 32 bit
#
# 2. OAUTH 2.0 (Client ID + Client Secret):
#    - Used for: Payment Links API, Split Payouts, newer PayU APIs
#    - Location in your dashboard: Developers → Client ID & Client secret
#    - NOT needed for the basic checkout flow we use.
#
# See: https://devguide.payu.in/integrations/payu-checkout/legacy-hash/
# ──────────────────────────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=          # Your PayU "key" (from Dashboard → API Keys)
PAYU_MERCHANT_SALT=         # Your PayU "Salt- 32 bit" (NOT the 256-bit salt)
PAYU_MODE=test              # "test" for staging, "live" for production
PAYU_REDIRECT_BASE=http://localhost:3000  # Frontend URL for PayU redirects

# PayU web checkout form POST URLs:
#   Test: https://test.payu.in/_payment
#   Live: https://secure.payu.in/_payment
# (Auto-detected from PAYU_MODE — no env var needed)
# ──────────────────────────────────────────────────────────────────────────
# Your test dashboard credentials (PayU Test):
#   MID:  8792397
#   Key:  tltpgm
#   Salt: UewqWeB1yAwyaVDFQmveOUWYQd06sjYJ
# ⚠️  NEVER COMMIT REAL CREDENTIALS!
# ──────────────────────────────────────────────────────────────────────────

# SendPulse (LTD transactional emails — code delivery)
# Get from: SendPulse Dashboard → SMTP → Settings
SENDPULSE_CLIENT_ID=
SENDPULSE_CLIENT_SECRET=

# RevenueCat webhooks (required when ENVIRONMENT is production/staging)
REVENUECAT_WEBHOOK_SECRET=

# OCI Object Storage
OCI_CONFIG_FILE=/app/oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_BUCKET_NAME=your-bucket-name-from-console
OCI_NAMESPACE=your-object-storage-namespace
OCI_PAR_EXPIRY_HOURS=1

# ──────────────────────────────────────────────────────────────────────────
# OpenObserver (unified observability: logs, metrics, traces)
# All vars below are used by both docker-compose.yml and docker-compose.prod.yml.
# Use .env.dev for local development, .env.prod for production.
# ──────────────────────────────────────────────────────────────────────────

# App → OpenObserver connection (container name, resolves inside Docker)
OPENOBSERVER_ENDPOINT=http://openobserver:5001

# API key for OTLP ingestion. Generate in OpenObserver UI → Settings → API Keys.
# Leave empty for dev (no auth).
OPENOBSERVER_API_KEY=

# Service name tag for all observability signals
OPENOBSERVER_SERVICE_NAME=rizzbot-api

# Master switch and trace sampling (0.0–1.0). 0.1 = trace 10% of requests.
OTLP_ENABLED=true
OTLP_SAMPLE_RATE=0.1

# ── OpenObserver admin credentials ───────────────────────────────────────
# These configure the OpenObserver container itself (not the app).
# Required on FIRST startup. Generate a strong password for production:
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#%^&*') for _ in range(28)))"
ZO_ROOT_USER_EMAIL=admin@rizzbot.dev
ZO_ROOT_USER_PASSWORD=change-me-to-a-strong-random-password

# PostgreSQL connection for OpenObserver metadata storage.
# Both dev and prod now use Postgres (not SQLite).
# The 'openobserver' database is auto-created by initdb/002_create_openobserver_db.sql.
# ZO_META_STORE=postgres is required to select the Postgres backend — without
# it OpenObserve silently ignores the DSN and falls back to its bundled SQLite.
ZO_META_STORE=postgres
ZO_META_POSTGRES_DSN=postgres://cookd:cookd@postgres:5432/openobserver

# Data directory for OpenObserver's internal columnar storage
ZO_DATA_DIR=/data

# ──────────────────────────────────────────────────────────────────────────
# Nginx Proxy Manager (production only)
# Web UI for reverse proxy + Let's Encrypt SSL certificate management.
# Runs on ports: 80 (HTTP), 443 (HTTPS), 81 (admin UI).
# ──────────────────────────────────────────────────────────────────────────

# First-time admin credentials (CHANGE ON FIRST LOGIN):
#   Email:    admin@example.com
#   Password: changeme
#
# After login, go to:
#   1. Access Management → Change admin email & password
#   2. Proxy Hosts → Add a proxy host for api.yourdomain.com → api:8000
#   3. SSL tab → Request a new SSL certificate → Force SSL
#
# NPM uses its own SQLite database stored in the npm_data volume —
# no additional database service is needed.

# ──────────────────────────────────────────────────────────────────────────
# Admin API — shared secret between Next.js BFF and FastAPI backend
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ──────────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-to-a-random-secret
# Backend URL that Next.js BFF proxies to (Docker service name in compose, localhost for local dev)
BACKEND_URL=http://api:8000

# ──────────────────────────────────────────────────────────────────────────
# Landing Page (Next.js)
# ──────────────────────────────────────────────────────────────────────────

# Clerk (admin auth for /admin dashboard)
# Get these from https://clerk.com → your app → API Keys
# ── Security: prevent self-signup ────────────────────────────────────────
# In the Clerk Dashboard, go to:
#   User & Authentication → Email, Phone, Username
#     → Disable "Email" as an authentication strategy
#   User & Authentication → Restrictions
#     → Enable "Allowlist only" → add only YOUR email address
# This ensures only you can sign in — no one can create an account on their own.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
