<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RizzBot" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.RizzBot.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#121212</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_rizzbot</item>
        <item name="postSplashScreenTheme">@style/Theme.RizzBot</item>
    </style>
</resources>
